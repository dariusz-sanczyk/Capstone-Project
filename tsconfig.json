{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",                 
    "outDir": "./dist/js",                  
    "rootDir": "./src/ts",                  
    "strict": true,                      
    "esModuleInterop": true,             
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,                
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": false,                    
  },
  "include": [
    "src/ts/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}